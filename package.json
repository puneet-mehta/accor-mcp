{
  "name": "accor-mcp",
  "private": true,
  "version": "1.0.0",
  "description": "MCP server for searching Accor hotels and special rates",
  "type": "module",
  "bin": {
    "accor-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x build/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:http": "MCP_TRANSPORT=http tsx watch src/index.ts",
    "start": "node build/index.js",
    "start:http": "MCP_TRANSPORT=http node build/index.js",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js"
  },
  "files": [
    "build"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.0.0",
    "express": "^5.2.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
